# Skip preflight check for faster builds
SKIP_PREFLIGHT_CHECK=true

# Disable source maps in production builds
GENERATE_SOURCEMAP=false

# API endpoint (optional, defaults to localhost)
# REACT_APP_API_URL=http://localhost:3001

# OpenTelemetry Web Tracing
REACT_APP_TRACING_ENABLED=true
REACT_APP_OTEL_ENDPOINT=http://localhost:4318/v1/traces
REACT_APP_TRACE_SAMPLE_RATE=0.01
REACT_APP_MAX_TRACES_PER_MINUTE=1000
REACT_APP_VERSION=1.0.0

# Backend
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="file:./dev.db"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# CORS
# Comma-separated allowlist of origins. Example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=
CORS_ALLOW_ALL=false
CORS_CREDENTIALS=false

# Express trust proxy (set when behind reverse proxy / load balancer)
# TRUST_PROXY=1
TRUST_PROXY=

# Monitoring / Observability
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CONSOLE=true
LOG_FILE=false
LOG_FILE_PATH=logs/app.log
LOG_MAX_FILES=14
LOG_MAX_SIZE=20m

METRICS_ENABLED=true
METRICS_PREFIX=chenaikit
METRICS_PORT=9090
SERVICE_NAME=chenaikit-backend
APP_VERSION=1.0.0

TRACING_ENABLED=false
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRACE_SAMPLE_RATE=0.1

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

ALERTING_ENABLED=false
ALERT_ERROR_THRESHOLD=10
ALERT_LATENCY_THRESHOLD=5000
ALERT_WEBHOOK_URL=

# HashiCorp Vault (optional)
VAULT_ENABLED=false
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_VERSION=2
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=chenaikit/backend

# File storage (local | s3; gcs/azure can be registered as adapters)
STORAGE_PROVIDER=local
STORAGE_MIRROR_PROVIDERS=
STORAGE_LOCAL_ROOT=uploads
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf,text/plain,text/csv,application/json,application/zip
STORAGE_SIGNED_URL_TTL_SECONDS=900
STORAGE_SIGNED_URL_SECRET=
STORAGE_CDN_BASE_URL=
STORAGE_CACHE_CONTROL=public, max-age=31536000, immutable
STORAGE_IMAGE_MAX_WIDTH=2048
STORAGE_IMAGE_MAX_HEIGHT=2048
STORAGE_IMAGE_QUALITY=82
STORAGE_THUMBNAIL_WIDTH=320
STORAGE_THUMBNAIL_HEIGHT=320
STORAGE_VIRUS_SCAN_COMMAND=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=false

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String
  password      String
  role          String          @default("user")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]

  @@index([createdAt])
  @@index([email])
  @@index([role])
  @@index([email, role])
  @@index([deletedAt])
}


model RefreshToken {
  id         Int      @id @default(autoincrement())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime

  @@index([userId, expiresAt])
  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model ApiKey {
  id            String   @id @default(cuid())
  keyHash       String   @unique
  name          String
  tier          String   @default("FREE") // FREE, PRO, ENTERPRISE
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  isActive      Boolean  @default(true)
  allowedIps    String   @default("") // JSON string array of allowed IP addresses
  allowedPaths  String   @default("") // JSON string array of allowed path patterns
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expiresAt     DateTime?
  lastUsedAt    DateTime @default(now())
  usageQuota    Int?     // Monthly quota if applicable
  currentUsage  Int      @default(0)
  usageResetAt  DateTime @default(now())
  deletedAt     DateTime?

  // Relations
  usageLogs     ApiUsage[]

  @@map("api_keys")
  @@index([userId, isActive])
  @@index([expiresAt])
  @@index([lastUsedAt])
  @@index([tier])
  @@index([keyHash])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, tier])
}

model ApiUsage {
  id           String   @id @default(cuid())
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int      // in milliseconds
  requestSize  Int      // in bytes
  responseSize Int      // in bytes
  ip           String
  userAgent    String?
  timestamp    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@map("api_usage")
  @@index([apiKeyId, timestamp])
  @@index([endpoint, timestamp])
  @@index([statusCode, timestamp])
  @@index([ip, timestamp])
  @@index([timestamp])
  @@index([apiKeyId])
  @@index([method])
  @@index([responseTime])
  @@index([deletedAt])
  @@index([apiKeyId, statusCode])
}


model Webhook {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url             String
  secret          String   // HMAC secret for signature verification
  eventTypes      String   // JSON array of event types
  isActive        Boolean  @default(true)
  isPaused        Boolean  @default(false)
  allowedIps      String   @default("") // JSON array of allowed IP addresses
  headers         String   @default("") // JSON object of custom headers
  retryConfig     String   @default("") // JSON object with retry configuration
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  deliveries      WebhookDelivery[]

  @@map("webhooks")
  @@index([userId, isActive])
  @@index([eventTypes])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, isPaused])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookId       String
  webhook         Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType       String
  payload         String   // JSON payload
  responseStatus  Int?
  responseBody    String?
  attemptCount    Int      @default(0)
  nextRetryAt     DateTime?
  succeededAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@map("webhook_deliveries")
  @@index([webhookId, createdAt])
  @@index([eventType, createdAt])
  @@index([responseStatus])
  @@index([nextRetryAt])
  @@index([succeededAt])
  @@index([failedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([webhookId, eventType])
}

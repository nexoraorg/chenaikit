{
  "name": "@chenaikit/backend",
  "version": "0.1.0",
  "description": "Backend services for ChenAIKit",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "pnpm run prisma:generate && tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "docs:generate-types": "ts-node scripts/generate-types.ts",
    "docs:export": "ts-node -e \"const {swaggerSpec}=require('./src/config/swagger');require('fs').writeFileSync('./openapi.json',JSON.stringify(swaggerSpec,null,2));console.log('Exported to openapi.json')\"",
    "docs:validate": "npx @apidevtools/swagger-cli validate openapi.json"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@chenaikit/core": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.64.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.54.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "@prisma/client": "^5.0.0",
    "@sentry/node": "^8.30.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "sql.js": "^1.14.1",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.14.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.1.14",
    "openapi-typescript": "^7.13.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
